# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/uk_ops_bd

# Redis
REDIS_URL=redis://redis:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# External API Keys
COMPANIES_HOUSE_API_KEY=your_key_here
APOLLO_API_KEY=your_key_here
HUNTER_API_KEY=your_key_here

# HM Land Registry CCOD (Corporate & Commercial Ownership Data)
# Download from: https://use-land-property-data.service.gov.uk/datasets/ccod
HMLR_CCOD_DOWNLOAD_URL=https://use-land-property-data.service.gov.uk/datasets/ccod/download
HMLR_CCOD_LOCAL_PATH=  # e.g. /data/hmlr/CCOD_FULL_2024_03.zip

# EPC Open Data Communities API
EPC_API_KEY=your_email:your_api_key

# Planning Data API
PLANNING_DATA_API_URL=https://www.planning.data.gov.uk/api/v1

# Notifications
SLACK_WEBHOOK_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Monitoring
SENTRY_DSN=

# Proxy (for scraping)
PROXY_URL=

# Application
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:3000
